# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="Banking TTS Offline"
DEBUG=false
HOST=0.0.0.0
PORT=8000
API_V1_PREFIX=/api/v1

# ── TTS Engine ───────────────────────────────────────────────────────────────
# Set to true to use GPU for inference (requires CUDA)
TTS_USE_GPU=false

# Set to true to use the multilingual XTTS v2 model for all languages.
# XTTS v2 requires a speaker WAV reference file (TTS_XTTS_SPEAKER_WAV).
TTS_USE_XTTS=false
TTS_XTTS_SPEAKER_WAV=

# Directory where Coqui TTS caches downloaded model files
TTS_MODELS_CACHE_DIR=./tts_models_cache

# ── Per-Language Model Overrides (only used when TTS_USE_XTTS=false) ─────────
TTS_MODEL_EN=tts_models/en/ljspeech/tacotron2-DDC
TTS_MODEL_ES=tts_models/es/mai/tacotron2-DDC
TTS_MODEL_AR=tts_models/ar/cv/vits
TTS_MODEL_ZH=tts_models/zh-CN/baker/tacotron2-DDC-GST
TTS_MODEL_JA=tts_models/ja/kokoro/tacotron2-DDC
TTS_MODEL_FR=tts_models/fr/mai/tacotron2-DDC

# ── Defaults ─────────────────────────────────────────────────────────────────
DEFAULT_LANGUAGE=en
